services:
  telegram-bot-api:
    image: aiogram/telegram-bot-api:latest
    container_name: local-bot-api
    restart: unless-stopped
    environment:
      TELEGRAM_API_ID: ""
      TELEGRAM_API_HASH: ""
      TELEGRAM_LOCAL: "1"
    ports:
      - "8081:8081"
    volumes:
      # Changed from relative to absolute path
      - /opt/telegram-bot-api:/var/lib/telegram-bot-api